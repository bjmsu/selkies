prefix=/opt/conda/conda-bld/selkies-gstreamer_1723709211346/_h_env_placehold_placehold_placehold_placehold_placehold_placehold_placehold_placehold_placehold_placehold_placehold_placehold_placehold_placehold_placehold_placehold_placehold_placehold_placehold_place
datadir=${prefix}/share
includedir=${prefix}/include
libdir=${prefix}/lib
libexecdir=${prefix}/libexec

exec_prefix=${prefix}
toolsdir=${exec_prefix}/bin
pluginsdir=${libdir}/gstreamer-1.0
girdir=${datadir}/gir-1.0
typelibdir=${libdir}/girepository-1.0
pluginscannerdir=${libexecdir}/gstreamer-1.0
gl_platforms=egl glx
gl_winsys=egl surfaceless wayland x11
gl_apis=gles2 gl
libinc=-I${libdir}/gstreamer-1.0/include

Name: gstreamer-gl-1.0
Description: Streaming media framework, OpenGL plugins libraries
Version: 1.24.6
Requires: gstreamer-base-1.0, gstreamer-1.0, gstreamer-video-1.0
Requires.private: orc-0.4, gstreamer-allocators-1.0, glib-2.0 >=  2.64.0, gobject-2.0, gmodule-no-export-2.0, glesv2, opengl, egl, glx, wayland-client >=  1.11, wayland-cursor >=  1.0, wayland-egl >=  1.0, x11, x11-xcb
Libs: -L${libdir} -lgstgl-1.0
Libs.private: -lm -pthread
Cflags: -I${includedir}/gstreamer-1.0 ${libinc}
